# ── Required ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
SECRET_KEY=change-this-to-a-random-secret

# ── Database (defaults to SQLite for dev) ─────────────────
# DATABASE_URL=postgresql://user:pass@localhost/threatcommand

# ── Optional threat intel API keys ───────────────────────
# Get free keys at:
#   OTX: https://otx.alienvault.com
#   VirusTotal: https://www.virustotal.com
#   AbuseIPDB: https://www.abuseipdb.com
OTX_API_KEY=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
SHODAN_API_KEY=

# ── Scheduler ─────────────────────────────────────────────
THREAT_FEED_ENABLED=true
THREAT_FEED_HOUR=6        # Run daily at 06:00 UTC

# ── Alert Ingestion API ───────────────────────────────────
# Set this key and point Splunk/Sentinel/CrowdStrike webhooks to:
#   POST http://your-server:5001/api/v1/alerts
#   Header: X-API-Key: <this key>
INGEST_API_KEY=change-this-to-a-random-key

# ── Notifications ─────────────────────────────────────────
# Slack: get webhook from https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=
# Microsoft Teams
TEAMS_WEBHOOK_URL=
# Email (any SMTP — Gmail, SendGrid, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# Public URL for links in notifications
BASE_URL=http://localhost:5001

# ── Demo mode (Railway/Render — auto-seeds data on first boot) ────
DEMO_MODE=false

# ── Stripe billing ────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# Get from https://dashboard.stripe.com/webhooks after adding endpoint:
#   POST https://your-domain/billing/webhook
#   Events: checkout.session.completed, customer.subscription.*,  invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...
# Create a product + price at https://dashboard.stripe.com/products
# Copy the price ID (price_xxx) here
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PRO_PRICE_DISPLAY=$99/month

# ── Flask ─────────────────────────────────────────────────
FLASK_ENV=production
